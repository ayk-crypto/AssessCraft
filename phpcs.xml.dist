<?xml version="1.0"?>
<ruleset name="AssessCraft">
  <description>AssessCraft WordPress coding standards.</description>
  <file>assesscraft.php</file><file>admin</file><file>includes</file><file>integrations</file><file>uninstall.php</file>
  <exclude-pattern>vendor/*</exclude-pattern>
  <arg name="extensions" value="php"/><arg value="sp"/>
  <rule ref="WordPress"><exclude name="WordPress.Files.FileName.InvalidClassFileName"/></rule>
  <rule ref="PHPCompatibilityWP"><properties><property name="testVersion" value="8.0-"/></properties></rule>
</ruleset>
